<view class="container">
  <view class="header">
    <text class="title">记录拉屎</text>
  </view>

  <view class="form-card">
    <!-- 颜色 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-icon">🎨</text>
        <text>颜色</text>
      </view>
      <view class="option-btns">
        <view class="option-btn yellow {{color === 'yellow' ? 'active' : ''}}" bindtap="selectColor" data-color="yellow">黄色</view>
        <view class="option-btn green {{color === 'green' ? 'active' : ''}}" bindtap="selectColor" data-color="green">绿色</view>
        <view class="option-btn other {{color === 'other' ? 'active' : ''}}" bindtap="selectColor" data-color="other">其他</view>
      </view>
    </view>

    <!-- 形状 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-icon">💩</text>
        <text>形状</text>
      </view>
      <view class="option-btns">
        <view class="option-btn {{shape === 'loose' ? 'active' : ''}}" bindtap="selectShape" data-shape="loose">稀</view>
        <view class="option-btn {{shape === 'normal' ? 'active' : ''}}" bindtap="selectShape" data-shape="normal">正常</view>
        <view class="option-btn {{shape === 'dry' ? 'active' : ''}}" bindtap="selectShape" data-shape="dry">干</view>
      </view>
    </view>
  </view>

  <view class="save-btn" bindtap="save">保存</view>
</view>
