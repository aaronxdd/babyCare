<view class="container">
  <view class="header">
    <text class="title">我的</text>
  </view>

  <!-- 宝宝信息 -->
  <view class="profile-card">
    <view class="avatar-section">
      <image class="avatar" src="/assets/baby-avatar.png" mode="aspectFill" />
      <text class="avatar-hint">点击更换</text>
    </view>
    <view class="profile-form">
      <view class="form-item">
        <text class="form-label">宝宝小名</text>
        <input class="form-input" value="{{babyName}}" bindinput="onBabyNameChange" placeholder="请输入宝宝小名" />
      </view>
      <view class="form-item">
        <text class="form-label">出生日期</text>
        <picker mode="date" bindchange="onBirthDateChange">
          <view class="picker-value">
            {{birthDate || '请选择'}}
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-section">
    <view class="settings-title">设置</view>
    <view class="settings-list">
      <view class="settings-item">
        <text class="item-icon">🔔</text>
        <text class="item-text">提醒设置</text>
        <text class="item-arrow">›</text>
      </view>
      <view class="settings-item">
        <text class="item-icon">☁️</text>
        <text class="item-text">数据备份</text>
        <text class="item-arrow">›</text>
      </view>
      <view class="settings-item">
        <text class="item-icon">ℹ️</text>
        <text class="item-text">关于我们</text>
        <text class="item-arrow">›</text>
      </view>
    </view>
  </view>
</view>
