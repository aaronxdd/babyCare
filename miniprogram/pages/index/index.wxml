<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-content">
      <image class="baby-avatar" src="/assets/baby-avatar.png" mode="aspectFill" />
      <text class="app-title">宝贝记录</text>
    </view>
  </view>

  <!-- 快捷按钮 -->
  <view class="quick-actions">
    <view class="action-btn feed-btn" bindtap="goToFeed">
      <text class="action-icon">🍼</text>
      <text class="action-label">喂奶</text>
    </view>
    <view class="action-btn poop-btn" bindtap="goToPoop">
      <text class="action-icon">💩</text>
      <text class="action-label">拉屎</text>
    </view>
    <view class="action-btn urine-btn" bindtap="goToUrine">
      <text class="action-icon">💧</text>
      <text class="action-label">撒尿</text>
    </view>
  </view>

  <!-- 今日汇总 -->
  <view class="summary-card">
    <view class="summary-title">今日记录</view>
    <view class="summary-list">
      <view class="summary-item">
        <text class="summary-icon">🍼</text>
        <text class="summary-value">{{summary.feedCount}}次</text>
        <text class="summary-unit">/ {{summary.feedAmount}}ml</text>
      </view>
      <view class="summary-item">
        <text class="summary-icon">💩</text>
        <text class="summary-value">{{summary.poopCount}}次</text>
      </view>
      <view class="summary-item">
        <text class="summary-icon">💧</text>
        <text class="summary-value">{{summary.urineCount}}次</text>
      </view>
    </view>
  </view>
</view>
